{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../*"],
      "@privacy-shield/core": ["../../packages/core/src/index.ts"],
      "@privacy-shield/core/*": ["../../packages/core/*"]
    },
    "types": ["node"]
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
