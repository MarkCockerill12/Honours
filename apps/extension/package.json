{
  "name": "@privacy-shield/extension",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"next dev\" \"bun scripts/build-extension.js --watch\"",
    "build": "bun scripts/clean.js && bun scripts/build-extension.js && next build && bun scripts/rename-next.js && bun scripts/extract-inline-scripts.js && bun scripts/finalize-build.js",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rimraf .next out extension-dist .turbo"
  },
  "dependencies": {
    "@ghostery/adblocker": "^2.14.1",
    "@ghostery/adblocker-webextension": "^2.14.1",
    "@privacy-shield/core": "workspace:*",
    "animejs": "^3.2.2",
    "lucide-react": "^0.454.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.9",
    "@types/animejs": "^3.1.13",
    "@types/chrome": "^0.1.36",
    "@types/eslint__js": "^9.14.0",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "postcss": "^8.5",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "1.3.3",
    "vitest": "^4.1.1"
  }
}
