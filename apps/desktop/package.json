{
  "name": "@privacy-shield/desktop",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"cross-env PORT=3000 next dev\" \"wait-on -t 60000 http-get://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "build": "next build",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rimraf .next out .turbo",
    "postinstall": "node scripts/download-binaries.js"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.1011.0",
    "@ghostery/adblocker-electron": "^2.14.1",
    "@privacy-shield/core": "workspace:*",
    "animejs": "^3.2.2",
    "cross-fetch": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.454.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.9",
    "@types/animejs": "^3.1.13",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.4.1",
    "eslint": "^10.1.0",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "1.3.3",
    "wait-on": "^9.0.4"
  }
}
