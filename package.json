{
    "name": "my-v0-project",
    "version": "0.1.0",
    "private": true,
    "main": "electron/main.js",
    "scripts": {
        "dev": "next dev",
        "build": "node scripts/build-extension.js && next build && node scripts/rename-next.js && node scripts/extract-inline-scripts.js && xcopy /E /I /Y extension-dist out",
        "start": "next start",
        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "clean": "node scripts/clean.js",
        "desktop": "npm run dev:desktop",
        "dev:desktop": "concurrently -k \"cross-env PORT=3000 next dev\" \"wait-on -t 60000 http-get://localhost:3000/desktop && cross-env ELECTRON_START_URL=http://localhost:3000/desktop electron .\"",
        "dev:extension": "concurrently -k \"next dev\" \"node scripts/build-extension.js --watch\"",
        "dev:all": "concurrently -k \"cross-env PORT=3000 next dev\" \"wait-on -t 60000 http-get://127.0.0.1:3000/desktop && cross-env ELECTRON_START_URL=http://127.0.0.1:3000/desktop electron .\" \"node scripts/build-extension.js --watch\"",
        "preinstall": "npx only-allow pnpm"
    },
    "dependencies": {
        "@ghostery/adblocker": "^2.14.1",
        "@ghostery/adblocker-electron": "^2.14.1",
        "@ghostery/adblocker-webextension": "^2.14.1",
