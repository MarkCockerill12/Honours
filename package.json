{
  "name": "privacy-shield",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:desktop": "pnpm --filter @privacy-shield/desktop dev",
    "dev:extension": "pnpm --filter @privacy-shield/extension dev",
    "dev:mobile": "pnpm --filter @privacy-shield/mobile dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    "clean:workspaces": "rimraf **/node_modules",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.37",
    "@types/eslint__js": "^9.14.0",
    "@types/node": "^22.19.13",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^10.0.1",
    "globals": "^15.15.0",
    "rimraf": "^6.0.1",
    "typescript": "^5",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@10.12.1"
}
