# Privacy Shield - Environment Configuration Example
# Copy this file to .env.local and fill in your values.

# AWS Credentials (Required for VPN Orchestration)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY

# WireGuard Client Configuration
WG_CLIENT_PRIVATE_KEY=YOUR_CLIENT_PRIVATE_KEY

# VPN Hub Configuration (AwesomeVPN)
WG_HUB_PUBLIC_KEY=YOUR_HUB_PUBLIC_KEY

# VPN Spoke Configuration (Regional Handshake Keys)
WG_US_PUBLIC_KEY=
WG_UK_PUBLIC_KEY=
WG_DE_PUBLIC_KEY=
WG_JP_PUBLIC_KEY=
WG_AU_PUBLIC_KEY=

# API Keys (Optional)
GROQ_API_KEY=
DEEPL_KEY=
